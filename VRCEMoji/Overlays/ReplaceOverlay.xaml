<UserControl x:Class="VRCEMoji.Overlays.ReplaceOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <Grid>
        <!-- Backdrop -->
        <Border Background="#99000000"
                MouseLeftButtonDown="Backdrop_Click" />

        <!-- Centered card -->
        <Border Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="32"
                MinWidth="400" MaxWidth="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" ShadowDepth="20" Opacity="0.5" />
            </Border.Effect>

            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Replace Existing Emoji"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,4" />

                <!-- Subtitle -->
                <TextBlock x:Name="subtitleText"
                           FontSize="12"
                           Foreground="{StaticResource TextDisabledBrush}"
                           Margin="0,0,0,20" />

                <!-- Emoji grid -->
                <ItemsControl x:Name="emojiGrid"
                              Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="56"
                                    Height="56"
                                    Margin="3"
                                    BorderBrush="{StaticResource BorderInputBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Emoji_Click">
                                <Image Source="{Binding Thumbnail}"
                                       Stretch="Uniform"
                                       Margin="4" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Click="Cancel_Click" />
                    <Button x:Name="replaceBtn"
                            Grid.Column="2"
                            Content="Replace"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="Replace_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
