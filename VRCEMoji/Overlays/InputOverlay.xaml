<UserControl x:Class="VRCEMoji.Overlays.InputOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <Grid>
        <!-- Backdrop -->
        <Border Background="#99000000"
                MouseLeftButtonDown="Backdrop_Click" />

        <!-- Centered card -->
        <Border Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="32"
                MinWidth="360" MaxWidth="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" ShadowDepth="20" Opacity="0.5" />
            </Border.Effect>

            <StackPanel>
                <!-- Title -->
                <TextBlock x:Name="titleText" Text="Two-Factor Authentication"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,4" />

                <!-- Question -->
                <TextBlock x:Name="questionText"
                           FontSize="12"
                           Foreground="{StaticResource TextDisabledBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20" />

                <!-- Code label -->
                <TextBlock Text="Code"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="answerBox"
                         Style="{StaticResource DarkTextBox}"
                         FontSize="18"
                         Height="40"
                         HorizontalContentAlignment="Center"
                         Margin="0,0,0,24" />

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Click="Cancel_Click" />
                    <Button Grid.Column="2"
                            Content="Verify"
                            Style="{StaticResource PrimaryButton}"
                            Click="Ok_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
