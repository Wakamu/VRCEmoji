<Window x:Class="VRCEMoji.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        xmlns:overlays="clr-namespace:VRCEMoji.Overlays"
        xmlns:local="clr-namespace:VRCEMoji"
        mc:Ignorable="d"
        Title="VRCEmoji" Width="900" Height="650" MinWidth="800" MinHeight="600"
        Background="{StaticResource BackgroundBaseBrush}"
        WindowStartupLocation="Manual"
        ContentRendered="Window_ContentRendered"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Grid>
        <DockPanel>
            <!-- ══════════════ TITLE BAR ══════════════ -->
            <Border DockPanel.Dock="Top" Height="32"
                    Background="{StaticResource BackgroundDeepestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,0">
                <DockPanel VerticalAlignment="Center">
                    <!-- Right side: logout button -->
                    <Button x:Name="logoff" Content="Logout"
                            Style="{StaticResource SecondaryButton}"
                            DockPanel.Dock="Right"
                            Padding="8,2" FontSize="10"
                            Click="logoff_Click"
                            Visibility="Collapsed" />
                    <!-- Login status (clickable) -->
                    <Border Background="Transparent" Cursor="Hand"
                            MouseLeftButtonDown="LoginStatus_Click">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="loginDot" Width="8" Height="8"
                                     Fill="#555555" Margin="0,0,6,0" />
                            <TextBlock x:Name="loggedLabel" Text="Not logged in"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ══════════════ STATUS BAR ══════════════ -->
            <Border DockPanel.Dock="Bottom" Height="24"
                    Background="{StaticResource BackgroundDeepestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,0">
                <TextBlock x:Name="statusText" Text="Ready"
                           FontSize="10"
                           Foreground="{StaticResource TextDisabledBrush}"
                           VerticalAlignment="Center" />
            </Border>

            <!-- ══════════════ TAB BAR ══════════════ -->
            <Border DockPanel.Dock="Top" Height="36"
                    Background="{StaticResource BackgroundDeepestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="createTab" Content="Create"
                                 Style="{StaticResource TabButton}"
                                 IsChecked="True"
                                 Checked="createTab_Checked" />
                    <RadioButton x:Name="manageTab" Content="Manage"
                                 Style="{StaticResource TabButton}"
                                 Checked="manageTab_Checked" />
                </StackPanel>
            </Border>

            <!-- ══════════════ MAIN CONTENT ══════════════ -->
            <Grid>
                <!-- ═══ CREATE TAB CONTENT ═══ -->
                <Grid x:Name="createContent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT PANEL: Controls ─── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundPanelBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Bottom buttons pinned -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12">
                            <Button x:Name="generate" Content="Generate"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="32" Margin="0,0,0,6"
                                    Click="generate_Click" IsEnabled="False" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="save" Grid.Column="0" Content="Save"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28"
                                        Click="save_Click" IsEnabled="False" />
                                <Button x:Name="upload" Grid.Column="2" Content="Upload"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="28"
                                        Click="upload_Click" IsEnabled="False" />
                            </Grid>
                        </StackPanel>

                        <!-- Scrollable controls -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="12,8,12,0">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                            </ScrollViewer.Resources>
                            <StackPanel>
                                <!-- Open button -->
                                <Button x:Name="open" Content="Open Image..."
                                        Style="{StaticResource PrimaryButton}"
                                        Height="32" Margin="0,0,0,12"
                                        Click="open_Click" />

                                <!-- Generation Type -->
                                <TextBlock Text="Type"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="generationTypeBox"
                                          Style="{StaticResource DarkComboBox}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="generationTypeBox_SelectionChanged" />

                                <!-- ═══ FRAMES section ═══ -->
                                <Border Background="Transparent" Cursor="Hand"
                                        Margin="0,4,0,6"
                                        MouseLeftButtonDown="ToggleSection_Click"
                                        Tag="framesContent">
                                    <TextBlock x:Name="framesHeader"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}">
                                        <Run Text="&#x25BC;" /> <Run Text="FRAMES" />
                                    </TextBlock>
                                </Border>
                                <StackPanel x:Name="framesContent" Margin="0,0,0,8">
                                    <!-- Start -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="label1" Text="Start:"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="startSlider" Grid.Column="1"
                                                Style="{StaticResource DarkSlider}"
                                                Minimum="1" Maximum="0"
                                                SmallChange="0"
                                                IsSnapToTickEnabled="True"
                                                TickPlacement="None"
                                                ValueChanged="startSlider_ValueChanged" />
                                        <TextBlock x:Name="label2" Text=""
                                                   Grid.Column="2"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right" />
                                    </Grid>
                                    <!-- End -->
                                    <Grid x:Name="endSliderRow" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="label1_Copy" Text="End:"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="endSlider" Grid.Column="1"
                                                Style="{StaticResource DarkSlider}"
                                                Minimum="1" Maximum="0"
                                                SmallChange="0"
                                                IsSnapToTickEnabled="True"
                                                TickPlacement="None"
                                                ValueChanged="endSlider_ValueChanged" />
                                        <TextBlock x:Name="label2_Copy" Text=""
                                                   Grid.Column="2"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <!-- ═══ GENERATION section ═══ -->
                                <Border Background="Transparent" Cursor="Hand"
                                        Margin="0,4,0,6"
                                        MouseLeftButtonDown="ToggleSection_Click"
                                        Tag="generationContent">
                                    <TextBlock x:Name="generationHeader"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}">
                                        <Run Text="&#x25BC;" /> <Run Text="GENERATION" />
                                    </TextBlock>
                                </Border>
                                <StackPanel x:Name="generationContent" Margin="0,0,0,8">
                                    <!-- Mode -->
                                    <TextBlock x:Name="label1_Copy1" Text="Mode:"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,4" />
                                    <ComboBox x:Name="ConvertModeBox"
                                              Style="{StaticResource DarkComboBox}"
                                              IsEnabled="False"
                                              Margin="0,0,0,8" />
                                    <!-- Zoom -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="label1_Copy2" Text="Zoom:"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider x:Name="zoomSlider" Grid.Column="1"
                                                Style="{StaticResource DarkSlider}"
                                                Minimum="0.01" Maximum="1" Value="1"
                                                TickFrequency="0.1"
                                                AutoToolTipPlacement="BottomRight"
                                                AutoToolTipPrecision="2" />
                                    </Grid>
                                </StackPanel>

                                <!-- ═══ EFFECTS section ═══ -->
                                <Border Background="Transparent" Cursor="Hand"
                                        Margin="0,4,0,6"
                                        MouseLeftButtonDown="ToggleSection_Click"
                                        Tag="effectsContent">
                                    <TextBlock x:Name="effectsHeader"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#666666">
                                        <Run Text="&#x25B6;" /> <Run Text="CROP &amp; ZOOM" />
                                    </TextBlock>
                                </Border>
                                <StackPanel x:Name="effectsContent" Visibility="Collapsed" Margin="0,0,0,8">
                                    <CheckBox x:Name="cropBox" Content="Crop"
                                              Style="{StaticResource DarkCheckBox}"
                                              Margin="0,0,0,4"
                                              Checked="cropBox_Checked"
                                              Unchecked="cropBox_Unchecked" />
                                    <CheckBox x:Name="keepRatio" Content="Keep Ratio"
                                              Style="{StaticResource DarkCheckBox}"
                                              Margin="0,0,0,4" />
                                </StackPanel>

                                <!-- ═══ CHROMA KEY section ═══ -->
                                <Border Background="Transparent" Cursor="Hand"
                                        Margin="0,4,0,6"
                                        MouseLeftButtonDown="ToggleSection_Click"
                                        Tag="chromaContent">
                                    <TextBlock x:Name="chromaHeader"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#666666">
                                        <Run Text="&#x25B6;" /> <Run Text="CHROMA KEY" />
                                    </TextBlock>
                                </Border>
                                <StackPanel x:Name="chromaContent" Visibility="Collapsed" Margin="0,0,0,8">
                                    <CheckBox x:Name="chromaBox" Content="Enable ChromaKey"
                                              Style="{StaticResource DarkCheckBox}"
                                              Margin="0,0,0,6"
                                              IsEnabled="False"
                                              Checked="chromaBox_Checked"
                                              Unchecked="chromaBox_Unchecked" />
                                    <Button x:Name="chromaButton" Content=""
                                            Width="24" Height="24"
                                            HorizontalAlignment="Left"
                                            Background="Lime" Foreground="Lime"
                                            Click="chromaButton_Click"
                                            IsEnabled="False"
                                            Visibility="Collapsed"
                                            Margin="0,0,0,6" />
                                    <TextBlock x:Name="chromaTypeLabel" Text="Type:"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="Collapsed"
                                               Margin="0,0,0,4" />
                                    <ComboBox x:Name="chromaTypeBox"
                                              Style="{StaticResource DarkComboBox}"
                                              Visibility="Collapsed"
                                              Margin="0,0,0,6" />
                                    <TextBlock x:Name="threshold_label" Text="Threshold:"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="Collapsed"
                                               Margin="0,0,0,4" />
                                    <Grid Visibility="{Binding Visibility, ElementName=threshold_label}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="thresholdSlider"
                                                Style="{StaticResource DarkSlider}"
                                                Maximum="100" Value="30"
                                                SmallChange="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="thresholdSlider_ValueChanged" />
                                        <TextBlock x:Name="thresholdValue" Text="30"
                                                   Grid.Column="1"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ─── RIGHT PANEL: Previews ─── -->
                <Grid Grid.Column="1" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Source preview -->
                    <DockPanel Grid.Row="0">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="SOURCE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="sourceMetadata" Text=""
                                       FontSize="10"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Background="{StaticResource BackgroundDeepestBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                AllowDrop="True"
                                DragOver="SourcePreview_DragOver"
                                Drop="SourcePreview_Drop">
                            <Grid>
                                <TextBlock x:Name="sourceEmpty"
                                           Text="Open an image to get started"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDisabledBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <Image x:Name="originalGif"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                                <Canvas Background="Transparent"
                                        Name="canvas"
                                        MouseDown="Canvas_MouseDown"
                                        MouseMove="Canvas_MouseMove" />
                            </Grid>
                        </Border>
                    </DockPanel>

                    <!-- Result preview -->
                    <DockPanel Grid.Row="2">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="RESULT"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="resultMetadata" Text=""
                                       FontSize="10"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Background="{StaticResource BackgroundDeepestBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="resultEmpty"
                                           Text="Generate to see result"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDisabledBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <Viewbox Stretch="Uniform"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Margin="8">
                                    <Rectangle x:Name="resultRect"
                                               Width="256" Height="256"
                                               StrokeThickness="0">
                                    <Rectangle.Fill>
                                        <ImageBrush x:Name="resultBrush"
                                                    Stretch="UniformToFill"
                                                    AlignmentX="Left"
                                                    AlignmentY="Top">
                                            <ImageBrush.Transform>
                                                <MatrixTransform x:Name="SpriteSheetOffset" />
                                            </ImageBrush.Transform>
                                        </ImageBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </DockPanel>
                </Grid>
                </Grid>

                <!-- ═══ MANAGE TAB CONTENT ═══ -->
                <local:ManageView x:Name="manageView" />
            </Grid>
        </DockPanel>

        <!-- ══════════════ OVERLAY LAYER ══════════════ -->
        <overlays:LoginOverlay x:Name="loginOverlay" />
        <overlays:InputOverlay x:Name="inputOverlay" />
        <overlays:UploadOverlay x:Name="uploadOverlay" />
        <overlays:ReplaceOverlay x:Name="replaceOverlay" />
        <overlays:StatusOverlay x:Name="statusOverlay" />
        <overlays:EditOverlay x:Name="editOverlay" />
    </Grid>
</Window>
